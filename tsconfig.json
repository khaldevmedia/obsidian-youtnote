{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "strictBindCallApply": true,
        "exactOptionalPropertyTypes": true,
        "jsx": "react-jsx",
        "types": ["node"],
        "lib": [
            "DOM",
            "DOM.Iterable",
            "ES2022"
        ]
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "vite.config.ts"
    ]
}